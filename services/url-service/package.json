{
  "name": "url-service",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npm run build && npm start",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.instrumentation.json && mv dist/instrumentation.js dist/instrumentation.cjs",
    "start": "node dist/server.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "fastify": "^5.0.0",
    "nanoid": "^5.0.0",
    "pg": "^8.12.0",
    "pino": "^9.0.0",
    "prom-client": "^15.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.60.0",
    "@opentelemetry/sdk-trace-base": "^2.0.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.35.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.10",
    "eslint": "^9.0.0",
    "supertest": "^7.2.2",
    "typescript": "^5.5.0",
    "vitest": "^3.2.4"
  }
}
